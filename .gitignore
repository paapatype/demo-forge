# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
*.local

# Env (server-side secrets) — never commit
.env
.env.*
!.env.example

# Local disk library (your private client outputs — yours, not version-controlled)
library/*
!library/.gitkeep

# Logs & OS cruft
*.log
npm-debug.log*
.DS_Store

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
