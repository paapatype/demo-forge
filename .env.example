# Server-side only — never exposed to the client. Copy to .env (gitignored).
ANTHROPIC_API_KEY=

# Proxy port. The Vite dev server proxies /api -> http://localhost:PROXY_PORT.
# (Named PROXY_PORT, not PORT, because dev tooling/Vite commandeer PORT for the client.)
PROXY_PORT=3001

# Mock mode: 1 = the dropzone returns a fixture instead of calling the API (no key needed).
# The entire UI is exercisable in mock mode. Set to 0 for real analysis.
VITE_MOCK=1
