{
  "name": "demo-forge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Internal IndexArch tool: manufacturer PDF -> editable, branded, interactive web catalogue",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm:client\" \"npm:server\"",
    "client": "vite",
    "server": "tsx watch server/index.ts",
    "build": "vite build && vite build --config vite.viewer.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/libre-baskerville": "^5.2.10",
    "@google/model-viewer": "^4.3.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "~5.9.0",
    "vite": "^8.0.16"
  }
}
